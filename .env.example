# LiteLLM Configuration (External - must be running)
# Start LiteLLM proxy: litellm --model anthropic/claude-3-5-sonnet-20241022 --port 4000
LITELLM_BASE_URL=http://localhost:4000
LITELLM_API_KEY=sk-loom-master-key
MODEL=open-large

# Loom SQLite Database
DATABASE_URL=sqlite:///./loom.db

# Graphiti Memory Service (Auto-started via docker-compose)
GRAPHITI_BASE_URL=http://localhost:8002

# OpenFang Tool Registry (Auto-started via docker-compose)
OPENFANG_URL=http://localhost:8001

# API Server
PORT=8000
HOST=0.0.0.0

# SLA Configuration
SLA_POLL_INTERVAL_SECONDS=300
MAX_RETRIES_PER_STATE=3
MAX_ESCALATIONS=3
MATCH_CONFIDENCE_THRESHOLD=0.75
